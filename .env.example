# Supabase (públicas — cliente)
NEXT_PUBLIC_SUPABASEV3_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASEV3_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Supabase (servidor — NO exponer en el cliente)
SUPABASEV3_SUPABASE_ANON_KEY=eyJ...
SUPABASEV3_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# PostgreSQL directo (solo para npm run setup:db local)
SUPABASEV3_POSTGRES_URL_NON_POOLING=postgres://...

# Escaneo YOLO en Vercel (obligatorio para detección real)
PS_SCANNER_URL=https://tu-servidor-python/scan

# Alternativa IA (opcional si no hay scanner YOLO)
PS_LOVABLE_API_KEY=
